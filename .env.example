# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=postgresql://username:password@localhost:5432/research_workspace

# ===========================================
# Session Configuration (REQUIRED)
# ===========================================
# Generate a secure random string for production
# Example: openssl rand -base64 32
SESSION_SECRET=your_very_secure_session_secret_here_make_it_long_and_random
# Set to false for local Docker with HTTP, true for production with HTTPS
COOKIE_SECURE=false

# ===========================================
# Keycloak Configuration
# ===========================================
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=epsilon
KEYCLOAK_AUTH_URL=http://localhost:8080/realms/epsilon/protocol/openid-connect/auth
KEYCLOAK_TOKEN_URL=http://localhost:8080/realms/epsilon/protocol/openid-connect/token
KEYCLOAK_CLIENT_ID=jobscheduler-oauth
KEYCLOAK_CLIENT_SECRET=your_keycloak_client_secret_here
KEYCLOAK_REDIRECT_URI=http://localhost:3005/api/auth/callback

# ===========================================
# GitHub OAuth Configuration (for Connect GitHub feature)
# ===========================================
# Get these from https://github.com/settings/applications/new
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:3005/api/github/callback

# ===========================================
# Server Configuration
# ===========================================
PORT=3005
NODE_ENV=development

# ===========================================
# Feature Flags
# ===========================================
# Enable/disable AI agent analysis for new jobs
AI_ENABLED=true
# Enable/disable ZKP (Zero-Knowledge Proof) for new jobs
ZKP_ENABLED=true
